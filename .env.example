# ============================================================
# AutoGenius — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── GROQ API ─────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── MODEL SELECTION ──────────────────────────────────────────
# Researcher Agent Model (fast, good at data extraction)
GROQ_RESEARCHER_MODEL=llama-3.3-70b-versatile

# Writer Agent Model (strong at structured writing)
GROQ_WRITER_MODEL=llama-3.3-70b-versatile

# Vision / Multimodal Chain Model
GROQ_VISION_MODEL=llama-3.3-70b-versatile

# ── AGENT CONFIGURATION ──────────────────────────────────────
# Max iterations per agent before it stops
AGENT_MAX_ITERATIONS=5

# Enable verbose agent logs (true/false)
AGENT_VERBOSE=true

# Temperature for LLM responses (0.0 = deterministic, 1.0 = creative)
RESEARCHER_TEMPERATURE=0.2
WRITER_TEMPERATURE=0.6
VISION_TEMPERATURE=0.7

# ── OUTPUT CONFIGURATION ─────────────────────────────────────
# Where agent reports get saved
OUTPUT_DIR=./outputs

# Save intermediate agent states (true/false)
SAVE_AGENT_STATES=true

# ── IMAGE GENERATION (Pollinations.ai — FREE, no key needed) ─
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt
POLLINATIONS_WIDTH=1280
POLLINATIONS_HEIGHT=720
POLLINATIONS_MODEL=flux

# ── APPLICATION ──────────────────────────────────────────────
APP_NAME=AutoGenius
APP_ENV=development
APP_DEBUG=true
